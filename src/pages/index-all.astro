---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';

const concepts = await getCollection('concepts');
const methodology = await getCollection('methodology');
const guides = await getCollection('guides');

let evidence: any[] = [];
try {
  evidence = await getCollection('evidence');
} catch (e) {
  // evidence collection may be empty
}
---

<Base
  title="索引"
  description="firel.cn 全部概念、方法论、指南、证据的完整索引。按类别和首发时间排列。"
>
  <h1>索引</h1>
  <p>firel.cn 全部内容的速查表。每条包含一句话定义和版本信息。</p>

  <h2>概念定义</h2>
  <table>
    <thead>
      <tr><th>概念</th><th>一句话定义</th><th>版本</th></tr>
    </thead>
    <tbody>
      {concepts.map((c) => (
        <tr>
          <td><a href={`/concepts/${c.id}`}>{c.data.title}</a></td>
          <td>{c.data.definition}</td>
          <td>v{c.data.version}</td>
        </tr>
      ))}
    </tbody>
  </table>

  <h2>方法论</h2>
  <table>
    <thead>
      <tr><th>主题</th><th>核心结论</th><th>版本</th></tr>
    </thead>
    <tbody>
      {methodology.map((m) => (
        <tr>
          <td><a href={`/methodology/${m.id}`}>{m.data.title}</a></td>
          <td>{m.data.conclusion}</td>
          <td>v{m.data.version}</td>
        </tr>
      ))}
    </tbody>
  </table>

  <h2>指南</h2>
  <table>
    <thead>
      <tr><th>问题</th><th>说明</th><th>版本</th></tr>
    </thead>
    <tbody>
      {guides.map((g) => (
        <tr>
          <td><a href={`/guides/${g.id}`}>{g.data.title}</a></td>
          <td>{g.data.description}</td>
          <td>v{g.data.version}</td>
        </tr>
      ))}
    </tbody>
  </table>

  {evidence.length > 0 && (
    <>
      <h2>实验证据</h2>
      <table>
        <thead>
          <tr><th>主题</th><th>核心结论</th><th>来源</th><th>版本</th></tr>
        </thead>
        <tbody>
          {evidence.map((e) => (
            <tr>
              <td><a href={`/evidence/${e.id}`}>{e.data.title}</a></td>
              <td>{e.data.conclusion}</td>
              <td>{e.data.source}</td>
              <td>v{e.data.version}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </>
  )}
</Base>
